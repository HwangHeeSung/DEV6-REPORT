# 서버 JAR 실행 시 (dev6-report.sh / systemd)
PORT=8993
HOST=0.0.0.0

# 개발 시 Spring Boot API 프록시 대상 (기본: http://localhost:8993)
# REACT_APP_API_PROXY_TARGET=http://localhost:8993

# 프로덕션 절대 URL (비우면 상대 경로 /api 사용 — 단일 JAR 배포 시 권장)
# REACT_APP_API_BASE_URL=

# Flyway — DB_VENDOR 로 마이그레이션 폴더 선택 (mysql | postgresql)
# 로컬 기본 mysql, Railway 는 SPRING_PROFILES_ACTIVE=railway → postgresql
# DB_VENDOR=mysql

# MySQL — Docker 컨테이너 argo_db_mysql8 (reportDb, BT Dashboard와 동일 서버)
# 로컬 Docker Desktop 사용 시: docker port argo_db_mysql8 로 포트 확인 후 localhost:포트 로 변경
MYSQL_HOST=100.100.107.115
MYSQL_PORT=3318
MYSQL_DATABASE=reportDb
MYSQL_USERNAME=BTREPORT
MYSQL_PASSWORD=BTREPORT

# JIRA (백엔드 API 프록시 — application.yml 기본값과 동일)
JIRA_BASE_URL=http://qa.bridgetec.co.kr/jira
JIRA_USERNAME=woos798
JIRA_PASSWORD=4072

# 프론트 JIRA 이슈 링크 (npm run build 시에만 적용, JAR 실행과 무관)
# REACT_APP_JIRA_BASE_URL=http://qa.bridgetec.co.kr/jira/browse
